{
  "title": "DeutschFlow Metrics",
  "panels": [
    {
      "type": "timeseries",
      "title": "AI Speaking Latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "http_server_requests_seconds_max{uri=~\"/api/speaking.*\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HikariCP DB Pool",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "hikaricp_connections_active", "refId": "A", "legendFormat": "Active" },
        { "expr": "hikaricp_connections_pending", "refId": "B", "legendFormat": "Pending" },
        { "expr": "hikaricp_connections_max", "refId": "C", "legendFormat": "Max" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]) / rate(http_server_requests_seconds_count[5m])",
          "refId": "A",
          "legendFormat": "5xx Error Rate"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "timezone": "browser",
  "refresh": "10s"
}
