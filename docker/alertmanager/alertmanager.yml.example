# ============================================================
# Alertmanager config — DeutschFlow
#
# SETUP (làm 1 lần trên EC2):
#   1. Tạo Telegram bot: nhắn @BotFather → /newbot → copy BOT TOKEN.
#   2. Lấy chat id: nhắn @userinfobot (hoặc thêm bot vào group rồi xem id).
#   3. cp alertmanager.yml.example alertmanager.yml
#   4. Điền <TELEGRAM_BOT_TOKEN> và <TELEGRAM_CHAT_ID> vào alertmanager.yml
#   5. docker compose -f docker-compose.prod.yml up -d alertmanager prometheus
#
# File THẬT (alertmanager.yml) chứa token → đã được .gitignore. Chỉ commit file .example này.
# ============================================================

global:
  resolve_timeout: 5m

route:
  receiver: 'telegram'
  group_by: ['alertname']
  group_wait: 30s        # gom các alert nổ gần nhau trong 30s thành 1 tin
  group_interval: 5m
  repeat_interval: 1h    # nếu vẫn đang lỗi, nhắc lại mỗi 1h
  routes:
    # Alert severity=critical (DbPoolExhausted, HighErrorRate) → nhắc lại dày hơn
    - matchers:
        - severity = "critical"
      repeat_interval: 15m

receivers:
  - name: 'telegram'
    telegram_configs:
      - bot_token: '<TELEGRAM_BOT_TOKEN>'
        chat_id: <TELEGRAM_CHAT_ID>          # số nguyên, KHÔNG để trong nháy
        api_url: 'https://api.telegram.org'
        parse_mode: 'HTML'
        send_resolved: true
        message: |
          {{ range .Alerts }}<b>{{ if eq .Status "firing" }}🔴{{ else }}✅{{ end }} {{ .Labels.alertname }}</b> ({{ .Labels.severity }})
          {{ .Annotations.summary }}
          {{ .Annotations.description }}
          {{ end }}

# ── (Tuỳ chọn) Slack thay cho Telegram — bỏ comment + sửa receiver ở route ──
