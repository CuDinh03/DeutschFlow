# ============================================================
# DeutschFlow — Frontend Environment Variables
# Copy thành .env.local cho local dev, hoặc set trong Amplify Console cho production.
# KHÔNG commit file chứa secret thật lên git.
# ============================================================

# ─── Backend API URL ──────────────────────────────────────────────────────────
# Local: http://localhost:8080
# Production: URL của EC2 instance hoặc Load Balancer
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# ─── JWT Secret (BẮT BUỘC — PHẢI khớp với backend JWT_SECRET) ───────────────
# ⚠️  QUAN TRỌNG: Nếu thiếu biến này, middleware sẽ từ chối mọi token hợp lệ
#     và redirect người dùng về /login ngay sau khi đăng nhập thành công.
#
# Cách lấy giá trị:
#   - Local: copy từ .env (giá trị JWT_SECRET của backend)
#   - Production: set trong AWS Amplify Console → App settings → Environment variables
JWT_SECRET=<same-value-as-backend-JWT_SECRET>

# ─── CloudFront (Media CDN) ───────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDFRONT_URL=https://dxxxxx.cloudfront.net

# ─── PostHog Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_SHARED_DASHBOARD_URL=https://us.posthog.com/shared/xxxxxxxx
