# =============================================================================
# MoMo — CHỈ dev / test / sandbox (test-payment.momo.vn)
# =============================================================================
# Copy vào file env backend khi chạy môi trường kiểm thử (vd. .env.local,
# .env.staging, hoặc file env của server staging). KHÔNG commit secret.
#
# KHÔNG dùng file này cho cổng thanh toán production (tiền thật / payment.momo.vn).
# =============================================================================
#
# Cách 1 — tên biến chuẩn MOMO_* (ưu tiên nếu set), vẫn chỉ sandbox nếu endpoint là test:
#   MOMO_PARTNER_CODE=...
#   MOMO_ACCESS_KEY=...
#   MOMO_SECRET_KEY=...
#   MOMO_API_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
#
# Cách 2 — biến DEV_* (đặt tên cho bộ key dev/test; backend map nếu không set MOMO_*):
#   DEV_MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api
#   DEV_PARTNER_CODE=...
#   DEV_ACCESS_KEY=...
#   DEV_SECRET_KEY=...
#
# =============================================================================

# Bật profile Spring: thanh toán chỉ đi qua MoMo sandbox (dev/test)
SPRING_PROFILES_ACTIVE=sandbox

# Ví dụ cách 2 (điền secret thật của bạn; đây chỉ là khung mẫu):
# DEV_MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api
# DEV_PARTNER_CODE=MOMOxxxx
# DEV_ACCESS_KEY=your_access_key
# DEV_SECRET_KEY=your_secret_key

# Hoặc cách 1 — đủ URL create:
# MOMO_API_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# MOMO_PARTNER_CODE=MOMO
# MOMO_ACCESS_KEY=...
# MOMO_SECRET_KEY=...

# IPN: MoMo POST JSON tới URL công khai. Mặc định app dùng cùng host frontend (Next rewrite → backend).
# Ghi đè nếu bạn chỉ mở subdomain API: MOMO_IPN_URL=https://api.example.com/api/payments/momo/ipn
# Local: ngrok https://....ngrok-free.app/api/payments/momo/ipn
MOMO_IPN_URL=https://mydeutschflow.com/api/payments/momo/ipn

# Trang Next.js sau thanh toán (MoMo redirect + query orderId)
MOMO_RETURN_URL=https://mydeutschflow.com/payment/success
