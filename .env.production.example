# ============================================================
# DeutschFlow — Production Environment Variables
# Copy file này thành .env.production và điền các giá trị thật
# KHÔNG BAO GIỜ commit file này lên git
# ============================================================

# ─────────────────────────────────────────────────────────────
# DATABASE (Amazon RDS PostgreSQL)
# Lấy endpoint sau khi tạo RDS instance trên AWS Console
# ─────────────────────────────────────────────────────────────
DB_HOST=<RDS_ENDPOINT>.rds.amazonaws.com
DB_PORT=5432
DB_NAME=deutschflow
DB_USERNAME=deutschflow_user
DB_PASSWORD=<STRONG_RANDOM_PASSWORD>

# ─────────────────────────────────────────────────────────────
# FLYWAY (database migrations)
# repair-before-migrate auto-aligns checksums of already-applied migrations. MUST stay false in
# prod (audit D-11): true would silently "fix" a tampered/edited applied migration instead of
# failing the deploy. App default is already false — set true only for local dev convenience.
# ─────────────────────────────────────────────────────────────
APP_FLYWAY_REPAIR_BEFORE_MIGRATE=false

# ─────────────────────────────────────────────────────────────
# JWT (bắt buộc ≥ 64 ký tự, random hoàn toàn)
# Tạo bằng lệnh: openssl rand -base64 64
# ─────────────────────────────────────────────────────────────
JWT_SECRET=<RUN: openssl rand -base64 64>
# Zero-downtime key rotation: khi đổi JWT_SECRET, set JWT_SECRET_PREVIOUS = secret cũ.
# Backend sẽ verify bằng cả 2 key trong ≥15 phút (TTL của access token).
# Sau đó bỏ JWT_SECRET_PREVIOUS và deploy lại.
# Nếu thiếu biến này khi đổi secret → toàn bộ user bị logout và refresh cũng fail.
JWT_SECRET_PREVIOUS=
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# ─────────────────────────────────────────────────────────────
# AI PROVIDER (dùng Groq API, không chạy model local)
# ─────────────────────────────────────────────────────────────
AI_CHAT_PROVIDER=groq
AI_SERVER_URL=http://localhost:8000

GROQ_API_KEY=<YOUR_GROQ_API_KEY>
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ─────────────────────────────────────────────────────────────
# EDGE TTS (Free — Microsoft Neural Voices)
# Python sidecar chạy trên cùng server, mặc định port 5050
# Tự động làm fallback khi ElevenLabs không configured
# ─────────────────────────────────────────────────────────────
EDGE_TTS_URL=http://localhost:5050

# ─────────────────────────────────────────────────────────────
# XTTS Streaming Voice Server (per-sentence streaming TTS, German)
# Empty → speaking stream omits audio events (edge-tts/on-device fallback).
# Dev: ngrok URL. Prod: fixed host (Cloud Run). See docs/XTTS_STREAMING_API_CONTRACT.md
# ─────────────────────────────────────────────────────────────
XTTS_BASE_URL=

# ─────────────────────────────────────────────────────────────
# OPENAI WHISPER STT — Phát âm + Audio timestamps
# Chi phí: ~$0.006/phút. Chỉ dùng cho pronunciation eval.
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# ─────────────────────────────────────────────────────────────
# ELEVENLABS TTS — TÙY CHỌN (Premium Voice Clone)
# Nếu để trống, hệ thống tự động dùng Edge TTS miễn phí
# ─────────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=<YOUR_ELEVENLABS_API_KEY>
# ELEVENLABS_VOICE_LUKAS=<VOICE_ID_LUKAS>
# ELEVENLABS_VOICE_EMMA=<VOICE_ID_EMMA>
# ELEVENLABS_VOICE_ANNA=<VOICE_ID_ANNA>
# ELEVENLABS_VOICE_KLAUS=<VOICE_ID_KLAUS>

# ─────────────────────────────────────────────────────────────
# CORS — Chỉ cho phép domain production của bạn
# Thay bằng domain thật sau khi mua
# ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://mydeutschflow.com,https://www.mydeutschflow.com

# ─────────────────────────────────────────────────────────────
# FRONTEND (Next.js)
# Nếu bạn deploy frontend riêng (Amplify / EC2), set biến này
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://api.mydeutschflow.com

# ─────────────────────────────────────────────────────────────
# PERFORMANCE TUNING (Production)
# Tắt auto-import vocab khi startup để tránh spike CPU
# Chạy import 1 lần qua Admin dashboard sau khi deploy
# ─────────────────────────────────────────────────────────────
GOETHE_AUTO_IMPORT_ON_STARTUP=false
GOETHE_OFFICIAL_WORDLIST_AUTO_IMPORT=false
CEFR_CURATED_AUTO_IMPORT_STARTUP=false

# ─────────────────────────────────────────────────────────────
# RATE LIMITING — Auth brute-force / abuse guard (TÙY CHỌN)
# In-memory sliding window per node. Bộ đếm reset mỗi khi restart/redeploy backend.
# Bỏ comment + chỉnh giá trị CHỈ KHI cần nới/siết; để trống = dùng default trong application.yml.
# Nới (tăng *_MAX hoặc giảm *_WINDOW) nếu user thật bị chặn nhầm — vd nhiều user chung
# 1 IP CGNAT của nhà mạng VN, hoặc QA test đăng ký liên tục.
# ─────────────────────────────────────────────────────────────
# Login — default 5 lần / 60s theo (IP + email)
# APP_AUTH_LOGIN_RL_MAX=5
# APP_AUTH_LOGIN_RL_WINDOW=60
# Register — default 10 lần / 600s theo IP (đã nới từ 3/3600s để không khoá user cả giờ)
# APP_AUTH_REGISTER_RL_MAX=10
# APP_AUTH_REGISTER_RL_WINDOW=600
# Refresh — default 10 lần / 60s theo IP
# APP_AUTH_REFRESH_RL_MAX=10
# APP_AUTH_REFRESH_RL_WINDOW=60

# Notification rate limit (TÙY CHỌN) — xem app.notifications.rate-limit.* trong application.yml
# APP_NOTIFICATION_READ_RL_MAX=120
# APP_NOTIFICATION_MUTATE_RL_MAX=40
# APP_NOTIFICATION_SSE_RL_MAX=20

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─────────────────────────────────────────────────────────────
# AWS S3 (Media Storage)
# ─────────────────────────────────────────────────────────────
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
AWS_S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# ─────────────────────────────────────────────────────────────
# GRAFANA (Observability Dashboard)
# Tạo bằng lệnh: openssl rand -base64 24
# ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<RUN: openssl rand -base64 24>

# ─────────────────────────────────────────────────────────────
# LOAD TEST (k6) — Password cho 5 user loadtest0[1-5]@test.com
# Đổi password này trên DB production nếu đã dùng LoadTest2026!
# Truyền khi chạy: k6 run --env LOADTEST_PASSWORD=<value> script.js
# ─────────────────────────────────────────────────────────────
# LOADTEST_PASSWORD=<STRONG_RANDOM_PASSWORD>
