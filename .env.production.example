# ============================================================
# DeutschFlow — Production Environment Variables
# Copy file này thành .env.production và điền các giá trị thật
# KHÔNG BAO GIỜ commit file này lên git
# ============================================================

# ─────────────────────────────────────────────────────────────
# DATABASE (Amazon RDS PostgreSQL)
# Lấy endpoint sau khi tạo RDS instance trên AWS Console
# ─────────────────────────────────────────────────────────────
DB_HOST=<RDS_ENDPOINT>.rds.amazonaws.com
DB_PORT=5432
DB_NAME=deutschflow
DB_USERNAME=deutschflow_user
DB_PASSWORD=<STRONG_RANDOM_PASSWORD>

# ─────────────────────────────────────────────────────────────
# JWT (bắt buộc ≥ 64 ký tự, random hoàn toàn)
# Tạo bằng lệnh: openssl rand -base64 64
# ─────────────────────────────────────────────────────────────
JWT_SECRET=<RUN: openssl rand -base64 64>
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# ─────────────────────────────────────────────────────────────
# AI PROVIDER (dùng Groq API, không chạy model local)
# ─────────────────────────────────────────────────────────────
AI_CHAT_PROVIDER=groq
AI_SERVER_URL=http://localhost:8000

GROQ_API_KEY=<YOUR_GROQ_API_KEY>
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ─────────────────────────────────────────────────────────────
# EDGE TTS (Free — Microsoft Neural Voices)
# Python sidecar chạy trên cùng server, mặc định port 5050
# Tự động làm fallback khi ElevenLabs không configured
# ─────────────────────────────────────────────────────────────
EDGE_TTS_URL=http://localhost:5050

# ─────────────────────────────────────────────────────────────
# OPENAI WHISPER STT — Phát âm + Audio timestamps
# Chi phí: ~$0.006/phút. Chỉ dùng cho pronunciation eval.
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# ─────────────────────────────────────────────────────────────
# ELEVENLABS TTS — TÙY CHỌN (Premium Voice Clone)
# Nếu để trống, hệ thống tự động dùng Edge TTS miễn phí
# ─────────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=<YOUR_ELEVENLABS_API_KEY>
# ELEVENLABS_VOICE_LUKAS=<VOICE_ID_LUKAS>
# ELEVENLABS_VOICE_EMMA=<VOICE_ID_EMMA>
# ELEVENLABS_VOICE_ANNA=<VOICE_ID_ANNA>
# ELEVENLABS_VOICE_KLAUS=<VOICE_ID_KLAUS>

# ─────────────────────────────────────────────────────────────
# CORS — Chỉ cho phép domain production của bạn
# Thay bằng domain thật sau khi mua
# ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://deutschflow.com,https://www.deutschflow.com

# ─────────────────────────────────────────────────────────────
# FRONTEND (Next.js)
# Nếu bạn deploy frontend riêng (Amplify / EC2), set biến này
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://api.deutschflow.com

# ─────────────────────────────────────────────────────────────
# PERFORMANCE TUNING (Production)
# Tắt auto-import vocab khi startup để tránh spike CPU
# Chạy import 1 lần qua Admin dashboard sau khi deploy
# ─────────────────────────────────────────────────────────────
GOETHE_AUTO_IMPORT_ON_STARTUP=false
GOETHE_OFFICIAL_WORDLIST_AUTO_IMPORT=false
CEFR_CURATED_AUTO_IMPORT_STARTUP=false

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
SERVER_PORT=8080
