## ============================================================
## DeutschFlow environment template (local development)
## Copy this file to .env and update values for your machine.
## ============================================================

# --- Backend server ---
SERVER_PORT=8080

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deutschflow
DB_USERNAME=postgres
DB_PASSWORD=change_me_postgres_password

# Compose healthcheck uses same vars; optional second DB:
# createdb deutschflow && set DB_NAME=deutschflow

# Flyway: auto-repair checksum drift on startup (local dev). Set false in production.
# APP_FLYWAY_REPAIR_BEFORE_MIGRATE=false

# --- JWT (MUST be at least 32 chars) ---
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- DeutschFlow AI (local fine-tuned model, không bắt buộc Groq cho chat) ---
AI_SERVER_URL=http://localhost:8000
# AI_CHAT_PROVIDER=local
# Hoặc: AI_CHAT_PROVIDER=groq và đặt GROQ_API_KEY (chat qua Groq API)
AI_LOCAL_MODEL_ID=deutschflow_model

# --- Optional: Groq (chỉ cần nếu dùng AI_CHAT_PROVIDER=groq và/hoặc Whisper speech-to-text) ---
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Other integrations ---
OPENAI_API_KEY=your_openai_api_key_here

# --- AWS S3 ---
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
AWS_S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

DEEPL_API_KEY=
# DeepL backfill scheduler (lemma DE→EN/VI); uses quota. Prod: often false.
# DEEPL_LEMMA_BACKFILL_ENABLED=true
# DEEPL_LEMMA_BACKFILL_BATCH_SIZE=25
# DEEPL_LEMMA_BACKFILL_MAX_CHARS=12000
# DEEPL_LEMMA_BACKFILL_TICK_MS=8000
#
# --- Vocabulary enrichment (Smart Free: auto-stop + DeepL FREE monthly hard cap UTC) ---
# APP_VOCAB_ENRICHMENT_AUTO_STOP=true
# APP_VOCAB_ENRICHMENT_AUTO_STOP_MIN_WORDS=10000
# APP_VOCAB_ENRICHMENT_AUTO_STOP_SCAN_MS=90000
# APP_VOCAB_STRICT_FREE=true
# DEEPL_FREE_MONTHLY_CHAR_CAP=490000
# Trần từ/request khi admin bấm chạy batch tay (scheduler dùng batch-size nhỏ hơn nhiều):
# GLOSBE_VI_ADMIN_MAX=10000
# WIKTIONARY_ENRICH_ADMIN_MAX=10000

# --- In-app notifications (SSE + retention; defaults in application.yml) ---
# APP_NOTIFICATION_SSE_TIMEOUT_MS=900000
# APP_NOTIFICATION_SSE_RL_MAX=20
# APP_NOTIFICATION_RETENTION_ENABLED=true
# APP_NOTIFICATION_RETENTION_READ_DAYS=90
# APP_NOTIFICATION_RETENTION_CRON=0 0 4 * * *
