## ============================================================
## DeutschFlow — Environment Variables Template
## Copy to .env and fill in real values before running.
## NEVER commit .env to git.
## ============================================================

# --- Backend server ---
SERVER_PORT=8080

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=deutschflow
DB_USERNAME=deutschflow_user
DB_PASSWORD=change_me_db_password

# Used only by docker compose (optional)
DB_ROOT_PASSWORD=change_me_root_password

# --- JWT (MUST be at least 32 chars) ---
# Generate: openssl rand -base64 32
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# --- CORS ---
# Comma-separated origins. In production, set to your real domain.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# AI Speaking Practice — Groq (Llama 4 Scout, free tier)
# ============================================================
# Get a free API key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ============================================================
# Vocabulary enrichment (all optional)
# ============================================================

# DeepL Free tier: ~500k chars/month
DEEPL_API_KEY=

# Goethe import config
GOETHE_AUTO_IMPORT_ON_STARTUP=true
GOETHE_OFFICIAL_WORDLIST_AUTO_IMPORT=true
GOETHE_WORDLIST_SOURCE=classpath
GOETHE_ENRICH_SOURCE=local_only
GOETHE_ENRICH_WITH_DEEPL=true
GOETHE_ENRICH_WITH_WIKTIONARY=false

# CEFR curated import (~10k words)
CEFR_CURATED_AUTO_IMPORT_STARTUP=true
CEFR_CURATED_AUTO_IMPORT_ENRICH=false
CEFR_CURATED_TARGET_TOTAL=10000
CEFR_CURATED_REMOTE_SOURCES=false

# Wiktionary IPA batch
WIKTIONARY_SCHEDULER_ENABLED=true
IPA_BATCH_WORDS_PER_RUN=200
IPA_BATCH_REQUEST_DELAY_MS=800

# Glosbe import (disabled by default)
GLOSBE_IMPORT_ENABLED=false
GLOSBE_VI_ENABLED=true

# App environment
APP_ENV=local
