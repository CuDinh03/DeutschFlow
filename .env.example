## ============================================================
## DeutschFlow environment template (local development)
## Copy this file to .env and update values for your machine.
## ============================================================

# --- Backend server ---
SERVER_PORT=8080

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=deutschflow
DB_USERNAME=deutschflow_user
DB_PASSWORD=change_me_db_password

# Used only by docker compose (optional)
DB_ROOT_PASSWORD=change_me_root_password

# --- JWT (MUST be at least 32 chars) ---
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=604800000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Optional AI integrations ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
DEEPL_API_KEY=
